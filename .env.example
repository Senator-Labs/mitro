# Mada Environment Configuration Template
# Copy this file to .env and customize for your local environment

# Path to the Mada test vault
# Default: ~/Mada_Test_Vault (created by scripts/setup_test_vault.sh)
MADA_VAULT_PATH=~/Mada_Test_Vault

# Enable performance logging (writes to ~/.mada_perf.jsonl)
# Set to 1 to enable, 0 to disable
MADA_PERF_LOG=1

# Rust backtrace level (useful for debugging)
# Options: 0 (off), 1 (minimal), full
RUST_BACKTRACE=1

# Log level for Mada application
# Options: error, warn, info, debug, trace
RUST_LOG=info
